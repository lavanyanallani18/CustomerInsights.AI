# Optional Hugging Face Llama-family answer model.
# The app falls back to deterministic cited extraction if this model is unavailable.
HF_LLM_ENABLED=true
HF_LLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
# Keep true for fast offline runs. Set false once if you want Transformers to
# download the public model from Hugging Face.
HF_LLM_LOCAL_ONLY=true

# Embedding model (local sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB path
CHROMA_DB_PATH=./chroma_db

# Data path
DATA_PATH=./data/sec
